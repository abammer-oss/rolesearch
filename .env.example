# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — Adzuna (https://developer.adzuna.com) adds mainstream job boards
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Model config (defaults shown)
MATCH_MODEL=claude-haiku-4-5-20251001
GENERATE_MODEL=claude-sonnet-4-6

# Scheduler interval in hours (default: 6)
REFRESH_INTERVAL_HOURS=6
